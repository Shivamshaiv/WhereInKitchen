rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Owner uid, or '' for legacy homes created before ownership existed.
    function ownerOf(data) {
      return data.get('ownerUid', '');
    }

    function isHouseholdMember(householdId) {
      return isSignedIn()
        && uid() in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // Per-user mapping to their active household.
    match /users/{userId} {
      allow read, write: if isSignedIn() && uid() == userId;
    }

    match /households/{householdId} {
      // Reading a household by id is allowed for any signed-in user: the id is
      // the invite "code", joining must look the home up before membership, and
      // the app queries `members arrayContains uid` to list/switch your homes.
      // (Closing this read fully needs a separate lookup doc / Cloud Function.)
      // The critical protection is the tightly-scoped `update`/`delete` below.
      allow read: if isSignedIn();

      // Create: the creator must be the sole member and the owner.
      allow create: if isSignedIn()
        && request.resource.data.members is list
        && request.resource.data.members == [uid()]
        && request.resource.data.ownerUid == uid();

      // Update: `members` may only change in tightly-controlled ways so no one
      // can add/evict OTHER users, and `ownerUid` is immutable. A missing owner
      // (legacy home) is treated as '' so join/leave still work on old homes.
      allow update: if isSignedIn()
        && ownerOf(request.resource.data) == ownerOf(resource.data)
        && (
          // (a) Non-membership edit (e.g. rename) by an existing member.
          ( uid() in resource.data.members
            && request.resource.data.members.toSet() == resource.data.members.toSet() )
          // (b) Join: add ONLY yourself (you weren't a member before).
          || ( !(uid() in resource.data.members)
            && request.resource.data.members.toSet()
                 == resource.data.members.toSet().union([uid()].toSet()) )
          // (c) Leave: a non-owner member removes ONLY themselves.
          || ( uid() in resource.data.members
            && uid() != ownerOf(resource.data)
            && request.resource.data.members.toSet()
                 == resource.data.members.toSet().difference([uid()].toSet()) )
          // (d) Owner removes other members (and never adds anyone).
          || ( uid() == ownerOf(resource.data)
            && request.resource.data.members.toSet()
                 .difference(resource.data.members.toSet()).size() == 0 )
        );

      // Only the owner may delete the home doc (contents are cascaded client-side).
      allow delete: if isSignedIn() && uid() == ownerOf(resource.data);

      match /{subcollection}/{docId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }
  }
}
